# ============================================================================
# dev-toolbox - .gitignore
# ============================================================================
# Archivos y directorios generados por el toolbox que no deben versionarse
# ============================================================================

# ============================================================================
# Archivos de Entorno y Configuración
# ============================================================================
.env
.env.*
!.env-template
!.env.template
!.env-example
!.env.example

# ============================================================================
# Estados y Versiones
# ============================================================================
.states/
.version
.validation-cache/

# ============================================================================
# Archivos Exportados
# ============================================================================
config.json
config.yaml
metrics.json
metrics.prom
*.export.json
*.export.yaml

# ============================================================================
# Backups y Archivos Temporales
# ============================================================================
*.bak.*
CHANGELOG.md.bak.*
*.tmp
*.temp
.tmp/
tmp/
backups/
*.backup
*.tar
*.tar.gz
*.tar.bz2
*.zip

# ============================================================================
# Logs
# ============================================================================
*.log
logs/
*.log.*
*.log.gz
.logging-config
!.logging-config.example

# ============================================================================
# BATS (instalación local)
# ============================================================================
.bats/

# ============================================================================
# Directorios de Datos y Contenedores
# ============================================================================
*_data/
postgres_data/
mongo_data/
rabbitmq_data/
containers/
volumes/

# ============================================================================
# Archivos de Desarrollo Local
# ============================================================================
.DS_Store
*/.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# Distribution / Packaging
# ============================================================================
node_modules/
bower_components/
build/
dist/
static/
uploads/
data/
.python-version

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*.pyc
*.so
*.pot
Pipfile*
pip-log.txt
pip-delete-this-directory.txt

# ============================================================================
# PyInstaller
# ============================================================================
*.manifest
*.spec

# ============================================================================
# Testing
# ============================================================================
test.db
*Testing.py
*_testing*
.coverage
.pytest_cache/
htmlcov/
coverage/
*.coverage.json
*.coverage.html

# ============================================================================
# Keys y Secretos
# ============================================================================
client_secret.json
*.pem
*.key
*.crt
secrets/
*.secret

# ============================================================================
# Archivos Temporales del Sistema
# ============================================================================
global_settings/local.*
global_settings/prod.*
